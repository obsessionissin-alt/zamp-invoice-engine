# PRIMARY (recommended): Groq — free, generous limits (30 RPM, 14,400/day)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# FALLBACK 1: Google Gemini — free vision tier (needed for scanned PDFs)
# Get your free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# FALLBACK 2 (optional): OpenAI — only used if both Groq AND Gemini fail
# Leave blank if you don't have a paid OpenAI account
OPENAI_API_KEY=
